@{
    ViewData["Title"] = "Transportes Turísticos Sakura - Cadena de Frío";
}

<div class="container my-4">
    <div class="row align-items-center g-5 mb-5 py-3">
        <div class="col-lg-7">
            <span class="badge slogan-badge-sakura mb-3">Unidad de Logística y Transporte</span>
            <div class="mb-4 text-start">
                <img src="~/img/sakura/sakura.png"
                     alt="Transportes Turísticos Sakura S.A."
                     class="img-fluid object-fit-contain logo-transparent"
                     style="max-height: 90px; width: auto; background-color: transparent;"
                     asp-append-version="true" />
            </div>

            <p class="lead text-muted mb-4">
                Especialistas de primer nivel en transporte refrigerado y cadena de frío a nivel nacional. Garantizamos el monitoreo constante de temperatura para proteger la integridad de sus productos biológicos, perecederos y de alta exigencia.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a href="#infraestructura" class="btn btn-corporate-blue px-4 py-2 fw-semibold shadow-sm">Nuestra Infraestructura</a>
                <a href="#contacto" class="btn btn-corporate-outline px-4 py-2 fw-semibold">
                    <i class="bi bi-envelope-fill text-primary"></i> Solicitar Ruta
                </a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="p-4 bg-white border rounded-3 shadow-sm position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 p-3 opacity-10">
                    <i class="bi bi-truck display-1 text-primary"></i>
                </div>
                <span class="text-primary fw-bold text-uppercase tracking-wider fs-7.5 d-block mb-1">Capacidad Total</span>
                <h3 class="h2 fw-black text-dark mb-3">Operación a Gran Escala</h3>

                <div class="d-flex align-items-center gap-3 mb-3">
                    <h4 class="display-5 fw-bold text-primary mb-0">80+</h4>
                    <p class="text-muted fs-7.5 mb-0 leading-sm"><strong>Unidades pesadas</strong> listas para la distribución nacional de alimentos.</p>
                </div>
                <hr class="my-3 text-black-50" />
                <div class="d-flex align-items-center gap-3">
                    <h4 class="display-6 fw-bold text-info mb-0">9</h4>
                    <p class="text-muted fs-7.5 mb-0 leading-sm"><strong>Grúas plataforma</strong> especializadas para el traslado de vehículos.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4 justify-content-center">
        <div class="col-md-6">
            <div class="bg-light-corporate p-4 rounded-3 border h-100 shadow-xs">
                <div class="icon-mv-wrapper bg-info-light text-info mb-3">
                    <i class="bi bi-bullseye fs-4"></i>
                </div>
                <h3 class="h5 fw-bold text-dark">Misión</h3>
                <p class="text-muted fs-7.5 leading-relaxed mb-0">
                    Garantizar la continuidad de la cadena de frío de nuestros clientes mediante un servicio de transporte refrigerado seguro, puntual y con los más altos estándares tecnológicos, preservando la calidad de los productos en cada kilómetro.
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="bg-light-corporate p-4 rounded-3 border h-100 shadow-xs">
                <div class="icon-mv-wrapper bg-info-light text-info mb-3">
                    <i class="bi bi-eye-fill fs-4"></i>
                </div>
                <h3 class="h5 fw-bold text-dark">Visión</h3>
                <p class="text-muted fs-7.5 leading-relaxed mb-0">
                    Ser la empresa de logística refrigerada líder y de referencia a nivel nacional, reconocida por nuestra confiabilidad absoluta, innovación en trazabilidad térmica y un firme compromiso con la sostenibilidad ambiental.
                </p>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5 justify-content-center text-center">
        <div class="col-sm-6 col-md-4">
            <a href="~/docs/brochure-sakura.pdf" class="btn btn-corporate-outline w-100 py-2.5 d-inline-flex align-items-center justify-content-center gap-2 shadow-2xs fw-semibold fs-7.5 text-dark" download>
                <i class="bi bi-file-earmark-pdf-fill text-danger fs-5"></i> Brochure Comercial Sakura
            </a>
        </div>
        <div class="col-sm-6 col-md-4">
            <a href="~/docs/sgc-calidad-sakura.pdf" class="btn btn-corporate-outline w-100 py-2.5 d-inline-flex align-items-center justify-content-center gap-2 shadow-2xs fw-semibold fs-7.5 text-dark" download>
                <i class="bi bi-shield-check text-success fs-5"></i> Descargar Política SGC
            </a>
        </div>
    </div>

    <div class="my-5 py-4 bg-white border rounded-3 p-4 shadow-xs" id="infraestructura">
        <div class="text-center mb-5">
            <span class="text-primary fw-bold text-uppercase tracking-widest fs-7.5">Soporte Propio</span>
            <h2 class="fw-bold text-dark tracking-tight mt-1">Garantía de Alta Confiabilidad</h2>
            <p class="text-muted">No tercerizamos el cuidado de nuestras herramientas; controlamos cada aspecto técnico e higiénico internamente.</p>
        </div>

        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-3 bg-light-corporate rounded-3 border h-100 d-flex flex-column">
                    <div class="mb-3 rounded border overflow-hidden bg-white shadow-2xs" style="height: 200px;">
                        <img src="~/img/sakura/personaltaller.png" alt="Taller de Mantenimiento" class="img-fluid object-fit-cover h-100 w-100" asp-append-version="true" />
                    </div>
                    <h4 class="h5 fw-bold text-dark mb-2">Taller Exclusivo</h4>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0 flex-grow-1">
                        Contamos con un centro técnico propio y mecánicos altamente calificados para revisiones preventivas continuas, asegurando el óptimo desempeño de la flota.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-3 bg-light-corporate rounded-3 border h-100 d-flex flex-column">
                    <div class="mb-3 rounded border overflow-hidden bg-white shadow-2xs" style="height: 200px;">
                        <img src="~/img/sakura/limpiezavehicular.png" alt="Higienización de Flota" class="img-fluid object-fit-cover h-100 w-100" asp-append-version="true" />
                    </div>
                    <h4 class="h5 fw-bold text-dark mb-2">Sanitización y Repuestos</h4>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0 flex-grow-1">
                        Procesos estrictos de lavado, desinfección térmica y stock crítico de autopartes para resolver incidencias de inmediato sin retrasar las rutas.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="p-3 bg-light-corporate rounded-3 border h-100 d-flex flex-column">
                    <div class="mb-3 rounded border overflow-hidden bg-white shadow-2xs" style="height: 200px;">
                        <img src="~/img/sakura/personalcarga.png" alt="Despacho Logístico" class="img-fluid object-fit-cover h-100 w-100" asp-append-version="true" />
                    </div>
                    <h4 class="h5 fw-bold text-dark mb-2">Depósitos y Despacho</h4>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0 flex-grow-1">
                        Amplios espacios de resguardo e infraestructura logística controlada que garantizan la alta confiabilidad y estricto orden en el despacho de las operaciones.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="my-5 py-2">
        <h2 class="fw-bold text-dark tracking-tight mb-4 text-center">Especialización en Cadena de Frío</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="bg-white rounded-3 border h-100 shadow-xs overflow-hidden text-center p-3">
                    <div class="mb-3 rounded-2 border overflow-hidden bg-light d-flex align-items-center justify-content-center" style="height: 90px;">
                        <img src="~/img/sakura/image_e86160.png" alt="Distribución de alimentos perecibles refrigerados" class="img-fluid object-fit-contain p-2" asp-append-version="true" />
                    </div>
                    <h4 class="h6 fw-bold text-dark mb-2">Transporte Refrigerado</h4>
                    <p class="text-muted fs-7.5 mb-0 leading-relaxed">Monitoreo exacto sobre rangos térmicos positivos para la correcta preservación de alimentos frescos e insumos sensibles.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-white rounded-3 border h-100 shadow-xs overflow-hidden text-center p-3">
                    <div class="mb-3 rounded-2 border overflow-hidden bg-light d-flex align-items-center justify-content-center" style="height: 90px;">
                        <img src="~/img/sakura/image_e86167.png" alt="Distribución de alimentos perecibles congelados" class="img-fluid object-fit-contain p-2" asp-append-version="true" />
                    </div>
                    <h4 class="h6 fw-bold text-dark mb-2">Carga Supercongelada</h4>
                    <p class="text-muted fs-7.5 mb-0 leading-relaxed">Estructuras preparadas y furgones equipados para soportar temperaturas bajo cero sostenidas en tramos logísticos de largo alcance.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="bg-white rounded-3 border h-100 shadow-xs overflow-hidden text-center p-3">
                    <div class="mb-3 rounded-2 border overflow-hidden bg-light d-flex align-items-center justify-content-center" style="height: 90px;">
                        <img src="~/img/sakura/image_e86180.png" alt="Distribución de alimentos no perecibles" class="img-fluid object-fit-contain p-2" asp-append-version="true" />
                    </div>
                    <h4 class="h6 fw-bold text-dark mb-2">Carga General y Seca</h4>
                    <p class="text-muted fs-7.5 mb-0 leading-relaxed">Soluciones versátiles y seguras de transporte terrestre para la distribución de alimentos secos y abarrotes generales.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 my-5 py-2 align-items-center">
        <div class="col-md-6">
            <div class="p-4 bg-white border rounded-3 h-100 d-flex align-items-center gap-4 shadow-xs">
                <div class="text-center">
                    <i class="bi bi-patch-check-fill text-primary display-4"></i>
                    <span class="d-block fw-bold text-dark mt-1 fs-7">ISO 9001</span>
                </div>
                <div>
                    <h4 class="h5 fw-bold text-dark mb-2">Sistema de Gestión de la Calidad</h4>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0">
                        Nuestras operaciones de transporte y logística se encuentran respaldadas bajo los lineamientos de la certificación internacional <strong>ISO 9001</strong>, asegurando la mejora continua en nuestros procesos.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="p-4 bg-white border rounded-3 h-100 d-flex align-items-center gap-4 shadow-xs">
                <div class="text-center">
                    <i class="bi bi-book-half text-warning display-4"></i>
                </div>
                <div>
                    <h4 class="h5 fw-bold text-dark mb-2">Libro de Reclamaciones</h4>
                    <p class="text-muted fs-7.5 leading-relaxed mb-3">
                        Conforme a lo estipulado por las normativas vigentes, ponemos a su disposición nuestro libro virtual para registrar cualquier inconveniente.
                    </p>
                    <a href="#" class="btn btn-sm btn-outline-secondary px-3">Acceder al Libro Virtual</a>
                </div>
            </div>
        </div>
    </div>

    <div class="my-5 py-4 bg-white border rounded-3 p-4 shadow-xs">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="rounded-3 border overflow-hidden shadow-sm">
                    <img src="~/img/sakura/personalcalificado.png" alt="Equipo Calificado Sakura S.A." class="img-fluid w-100 object-fit-cover" style="max-height: 380px;" asp-append-version="true" />
                </div>
            </div>
            <div class="col-lg-6">
                <span class="text-primary fw-bold text-uppercase tracking-widest fs-7.5">Capital Humano</span>
                <h2 class="fw-bold text-dark tracking-tight mt-1 mb-3">Nuestro Equipo Profesional</h2>
                <p class="text-muted leading-relaxed mb-3">
                    Contamos con ingenieros y personal operativo altamente certificado en Buenas Prácticas de Transporte (BPT) y manejo seguro de cargamentos refrigerados críticos.
                </p>
                <p class="text-muted leading-relaxed mb-0">
                    Nuestros conductores pasan por rigurosos controles de capacitación técnica y primeros auxilios mecánicos, asegurando que tu mercadería cuente con resguardo calificado y profesional las 24 horas del día, los 365 días del año.
                </p>
            </div>
        </div>
    </div>

    <div class="my-5 py-4 border-top border-bottom bg-light-corporate rounded-3 overflow-hidden">
        <h2 class="fw-bold text-dark tracking-tight mb-2 text-center fs-4">Empresas que confían en nosotros</h2>
        <p class="text-muted text-center mb-4 fs-7">Suministramos servicios logísticos a marcas e industrias exigentes</p>

        <div class="w-100 position-relative overflow-hidden">
            <div class="d-flex align-items-center gap-5 logos-marquee" style="animation: scrollLogos 25s linear infinite; width: max-content; white-space: nowrap;">

                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;">
                    <img src="~/img/sakura/cencosud.png" alt="Cencosud" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;">
                    <img src="~/img/sakura/zedina.png" alt="Zedina" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;">
                    <img src="~/img/sakura/delice.png" alt="Delice" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>

                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;" aria-hidden="true">
                    <img src="~/img/sakura/grupopana.png" alt="Grupo Pana" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;" aria-hidden="true">
                    <img src="~/img/sakura/cerdeña.png" alt="Zedina" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;" aria-hidden="true">
                    <img src="~/img/sakura/delice.png" alt="Delice" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>

            </div>
        </div>
    </div>

    <div class="row g-5 my-4" id="contacto">
        <div class="col-lg-6">
            <h2 class="fw-bold text-dark tracking-tight mb-3">Contáctanos</h2>
            <p class="text-muted leading-relaxed mb-4">
                Si requiere una cotización para rutas programadas, fletes consolidados o atención dedicada de cadena de frío, envíenos un mensaje y un asesor logístico lo asistirá de inmediato.
            </p>

            <form action="#" method="post" class="row g-3">
                <div class="col-md-6">
                    <label class="form-label text-dark fw-semibold fs-7.5">Nombre Completo</label>
                    <input type="text" class="form-control" placeholder="Ej. Juan Pérez" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label text-dark fw-semibold fs-7.5">Empresa</label>
                    <input type="text" class="form-control" placeholder="Ej. Corporación S.A." required />
                </div>
                <div class="col-12">
                    <label class="form-label text-dark fw-semibold fs-7.5">Correo Electrónico</label>
                    <input type="email" class="form-control" placeholder="nombre@correo.com" required />
                </div>
                <div class="col-12">
                    <label class="form-label text-dark fw-semibold fs-7.5">Mensaje o Requerimiento de Ruta</label>
                    <textarea class="form-control" rows="4" placeholder="Detalle los puntos de carga, descarga y temperatura requerida..." required></textarea>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-corporate-blue px-4 w-100 shadow-xs">Enviar Solicitud</button>
                </div>
            </form>
        </div>

