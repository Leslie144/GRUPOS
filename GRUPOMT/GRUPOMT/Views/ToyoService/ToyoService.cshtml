@{
    ViewData["Title"] = "Toyo Service - Alta Tecnología en Repintado";
}

<div class="container my-4">
    <div class="row align-items-center g-5 mb-5 py-3">
        <div class="col-lg-7">
            <span class="badge slogan-badge-toyo mb-3">Unidad Automotriz e Industrial</span>

            <div class="mb-4 text-start">
                <img src="~/img/toyo/toyo.png" alt="Toyo Service" class="img-fluid object-fit-contain" style="max-height: 85px; width: auto;" asp-append-version="true" />
            </div>

            <p class="lead text-muted mb-4">
                Líderes en el sector de pintura y repintado automotriz. Ofrecemos acabados con estándar original de fábrica utilizando laboratorios de color computarizados y cabinas de pintura presurizadas de última generación.
            </p>
            <div class="d-flex flex-wrap gap-3">
                <a href="#servicios" class="btn btn-corporate-red px-4 py-2 fw-semibold shadow-sm">Nuestros Servicios</a>
                <a href="https://wa.me/tu-numero" class="btn btn-corporate-outline px-4 py-2 fw-semibold" target="_blank">
                    <i class="bi bi-whatsapp text-success"></i> Cotizar por WhatsApp
                </a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="p-4 bg-white border rounded-3 shadow-sm position-relative overflow-hidden">
                <div class="position-absolute top-0 end-0 p-3 opacity-10">
                    <i class="bi bi-paint-bucket display-1 text-danger"></i>
                </div>
                <span class="text-danger fw-bold text-uppercase tracking-wider fs-7.5 d-block mb-1">Tecnología y Calidad</span>
                <h3 class="h2 fw-black text-dark mb-3">Estándar de Fábrica</h3>

                <div class="d-flex align-items-center gap-3 mb-3">
                    <h4 class="display-6 fw-bold text-danger mb-0"><i class="bi bi-cpu"></i></h4>
                    <p class="text-muted fs-7.5 mb-0 leading-sm"><strong>Laboratorio Computarizado</strong> para matizado y preparación exacta del color original.</p>
                </div>
                <hr class="my-3 text-black-50" />
                <div class="d-flex align-items-center gap-3">
                    <h4 class="display-6 fw-bold text-dark mb-0"><i class="bi bi-fire"></i></h4>
                    <p class="text-muted fs-7.5 mb-0 leading-sm"><strong>Cabinas Presurizadas</strong> con sistemas de horneado y flujo controlado de aire.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-5 justify-content-center text-center">
        <div class="col-sm-6 col-md-4">
            <a href="~/docs/brochure-toyo.pdf" class="btn btn-corporate-outline w-100 py-2.5 d-inline-flex align-items-center justify-content-center gap-2 shadow-2xs fw-semibold fs-7.5 text-dark" download>
                <i class="bi bi-file-earmark-pdf-fill text-danger fs-5"></i> Brochure Comercial Toyo
            </a>
        </div>
        <div class="col-sm-6 col-md-4">
            <a href="~/docs/brochure-grupo-mt.pdf" class="btn btn-corporate-outline w-100 py-2.5 d-inline-flex align-items-center justify-content-center gap-2 shadow-2xs fw-semibold fs-7.5 text-dark" download>
                <i class="bi bi-shield-check text-success fs-5"></i> Descargar Política SGC
            </a>
        </div>
    </div>


    <div class="my-5 py-4 border-top border-bottom bg-light-corporate rounded-3 overflow-hidden">
        <h2 class="fw-bold text-dark tracking-tight mb-2 text-center fs-4">Aliados Estratégicos</h2>
        <p class="text-muted text-center mb-4 fs-7">Tecnología de clase mundial</p>

        <div class="w-100 position-relative overflow-hidden mb-5">
            <div class="d-flex align-items-center gap-5 logos-marquee" style="animation: scrollLogos 25s linear infinite; width: max-content; white-space: nowrap;">
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;">
                    <img src="~/img/mt-representaciones.png" alt="MT Representaciones" class="img-fluid object-fit-contain" style="max-height: 100%;" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;">
                    <img src="~/img/sikkens.png" alt="Sikkens" class="img-fluid object-fit-contain" style="max-height: 100%;" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;">
                    <img src="~/img/wanda.png" alt="Wanda" class="img-fluid object-fit-contain" style="max-height: 100%;" />
                </div>
                <div class="bg-white p-3 rounded border shadow-2xs d-flex align-items-center justify-content-center mx-2" style="height: 80px; width: 180px; flex-shrink: 0;" aria-hidden="true">
                    <img src="~/img/toyo/grupopana.png" alt="Grupo Pana" class="img-fluid object-fit-contain" style="max-height: 100%;" asp-append-version="true" />
                </div>

            </div>
        </div>

        <div class="container text-center">
            <h3 class="fw-bold text-dark fs-5 mb-3">Talleres Autorizados por:</h3>
            <div class="d-flex justify-content-center gap-4 align-items-center flex-wrap">
                <div class="px-4 py-2 bg-white border rounded shadow-sm">
                    <img src="~/img/toyo/rimac.png" alt="Rimac Seguros" style="height: 50px;" />
                </div>
                <div class="px-4 py-2 bg-white border rounded shadow-sm">
                    <img src="~/img/toyo/mapfre.png" alt="Mapfre" style="height: 50px;" />
                </div>
            </div>
        </div>
    </div>
    <div class="my-5 py-4" id="servicios">
        <h2 class="fw-bold text-dark tracking-tight mb-4 text-center">Nuestra Especialidad</h2>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="bg-white p-4 rounded-3 border h-100 shadow-xs">
                    <div class="mb-3">
                        <img src="~/img/toyo/planchado.jpeg" alt="Planchado" class="img-fluid rounded" />
                    </div>
                    <h3 class="h5 fw-bold text-dark">Taller Especializado</h3>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0">Soluciones integrales de planchado, pintura, mecánica general y lavado de autos bajo un mismo techo.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="bg-white p-4 rounded-3 border h-100 shadow-xs">
                    <div class="icon-mv-wrapper bg-danger-light text-danger-corporate mb-3">
                        <i class="bi bi-cpu fs-4"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark">Alta Tecnología</h3>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0">Equipos de vanguardia <strong>Cellette</strong> y <strong>Termomeccanica</strong>, junto a centros de colorimetría para ajustes exactos.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="bg-white p-4 rounded-3 border h-100 shadow-xs">
                    <div class="icon-mv-wrapper bg-danger-light text-danger-corporate mb-3">
                        <i class="bi bi-palette fs-4"></i>
                    </div>
                    <h3 class="h5 fw-bold text-dark">Insumos Premium</h3>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0">Trabajamos exclusivamente con <strong>Sikkens</strong> y <strong>Wanda</strong>, líneas automotrices líderes de AkzoNobel.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="bg-white p-4 rounded-3 border h-100 shadow-xs">
                    <div class="mb-3">
                        <img src="~/img/toyo/perosnal.jpeg" alt="Planchado" class="img-fluid rounded" />
                    </div>
                    <h3 class="h5 fw-bold text-dark">Personal Calificado</h3>
                    <p class="text-muted fs-7.5 leading-relaxed mb-0">Contamos con un equipo humano altamente capacitado, enfocado en los estándares más exigentes de la industria.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-5 my-4" id="contacto">
        <div class="col-lg-6">
            <h2 class="fw-bold text-dark tracking-tight mb-3">Agendar Cita de Evaluación</h2>
            <p class="text-muted leading-relaxed mb-4">Seleccione su sede y envíenos los detalles para coordinar su atención.</p>

            <form action="/Citas/Registrar" method="post" class="row g-3">
                <div class="col-12">
                    <label class="form-label text-dark fw-semibold fs-7.5">Sede de su preferencia</label>
                    <select class="form-select" name="Sede" required>
                        <option value="" selected disabled>Seleccione una sede...</option>
                        <option value="SAN MIGUEL">Sede San Miguel (Taller Principal)</option>
                        <option value="ATE">Sede Ate (Planta Técnica)</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-dark fw-semibold fs-7.5">Nombre Completo</label>
                    <input type="text" name="Nombre" class="form-control" placeholder="Ej. Carlos Mendoza" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label text-dark fw-semibold fs-7.5">DNI</label>
                    <input type="text" name="Dni" class="form-control" placeholder="Ej. 12345678" maxlength="8" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label text-dark fw-semibold fs-7.5">Placa del Vehículo</label>
                    <input type="text" name="Placa" class="form-control" placeholder="Ej. ABC-123" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label text-dark fw-semibold fs-7.5">Teléfono Celular</label>
                    <input type="tel" name="Telefono" class="form-control" placeholder="Ej. 987654321" required />
                </div>
                <div class="col-12">
                    <label class="form-label text-dark fw-semibold fs-7.5">Modelo del Vehículo</label>
                    <input type="text" name="Vehiculo" class="form-control" placeholder="Ej. Toyota Hilux 2023" required />
                </div>
                <div class="col-12">
                    <label class="form-label text-dark fw-semibold fs-7.5">Motivo de la Cita</label>
                    <textarea name="Detalle" class="form-control" rows="4" placeholder="Describa el trabajo a realizar..." required></textarea>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-corporate-red px-4 w-100 shadow-xs">Solicitar Cita de Servicio</button>
                </div>
            </form>
        </div>

        <div class="col-lg-6">
            <h2 class="fw-bold text-dark tracking-tight mb-4">Nuestros Talleres Autorizados</h2>
            <ul class="nav nav-pills mb-3 gap-2" id="pills-tab-toyo" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active btn-sm py-1.5 px-3 fw-semibold border rounded-pill" id="pills-sanmiguel-tab" data-bs-toggle="pill" data-bs-target="#pills-sanmiguel" type="button" role="tab" aria-controls="pills-sanmiguel" aria-selected="true">
                        <i class="bi bi-geo-alt-fill me-1"></i> Sede San Miguel
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link btn-sm py-1.5 px-3 fw-semibold border rounded-pill" id="pills-ate-toyo-tab" data-bs-toggle="pill" data-bs-target="#pills-ate-toyo" type="button" role="tab" aria-controls="pills-ate-toyo" aria-selected="false">
                        <i class="bi bi-building-fill-gear me-1"></i> Sede Ate
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="pills-tabContentToyo">
                <div class="tab-pane fade show active" id="pills-sanmiguel" role="tabpanel" aria-labelledby="pills-sanmiguel-tab">
                    <div class="mb-3 d-flex align-items-start gap-2 bg-white p-3 rounded border shadow-2xs">
                        <i class="bi bi-geo-alt-fill text-danger mt-1 fs-5"></i>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark text-uppercase fs-7.5">Taller Principal - San Miguel</h5>
                            <p class="text-muted fs-7.5 mb-1">Especializado en pintura al horno premium, planchado y acabados con estándar original de fábrica.</p>
                            <span class="badge bg-danger-subtle text-danger fs-8 px-2 py-1">Centro Automotriz Premium</span>
                        </div>
                    </div>
                    <div class="ratio ratio-16x9 rounded-3 border overflow-hidden shadow-xs mb-3">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3901.5394409770215!2d-77.09356112493849!3d-12.07517718816384!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105c9656285dca5%3A0x28dd3b1d9b445810!2sToyo%20Service!5e0!3m2!1ses!2spe!4v1783820839787!5m2!1ses!2spe" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
                    </div>

                </div>

                <div class="tab-pane fade" id="pills-ate-toyo" role="tabpanel" aria-labelledby="pills-ate-toyo-tab">
                    <div class="mb-3 d-flex align-items-start gap-2 bg-white p-3 rounded border shadow-2xs">
                        <i class="bi bi-geo-alt-fill text-danger mt-1 fs-5"></i>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark text-uppercase fs-7.5">Planta Técnica - Sede Ate</h5>
                            <p class="text-muted fs-7.5 mb-1">Centro enfocado en mantenimiento de flotas comerciales pesadas y aplicación de pintura industrial anticorrosiva.</p>
                            <span class="badge bg-dark-subtle text-dark fs-8 px-2 py-1">Pintura e Infraestructura Industrial</span>
                        </div>
                    </div>
                    <div class="ratio ratio-16x9 rounded-3 border overflow-hidden shadow-xs mb-3">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3901.846753308915!2d-76.95785188962101!3d-12.054063088134036!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105c68dd6730399%3A0xaab198b72b645713!2sToyo%20Service%20-%20ATE!5e0!3m2!1ses!2spe!4v1783820879407!5m2!1ses!2spe" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin"></iframe>
                    </div>
                </div>
            </div>

            <div class="mt-3 p-3 bg-light border rounded-3 fs-7.5 text-muted">
                <i class="bi bi-clock-fill text-secondary me-1"></i>
                <strong>Horario de Operaciones en Talleres:</strong> Lunes a Viernes de 8:00 AM a 5:30 PM. Sábados de 8:00 AM a 1:00 PM. <br />
                <span class="text-dark fw-bold"><i class="bi bi-info-circle-fill text-danger me-1"></i> Puede agendar su cita de evaluación técnica previa vía WhatsApp para acelerar los tiempos de ingreso.</span>
            </div>
        </div>
    </div>
</div>

<style>
    #pills-tab-toyo .nav-link:hover {
        color: var(--mt-red-vibrant);
        background-color: #fff5f5;
        border-color: #fed7d7 !important;
    }

    #pills-tab-toyo .nav-link.active {
        color: #ffffff !important;
        background-color: var(--mt-red-vibrant) !important;
        border-color: var(--mt-red-vibrant) !important;
        box-shadow: 0 4px 12px rgba(227, 25, 25, 0.2);
    }
</style>